<form class="{{cssClass}}" autocomplete="off">
    <header class="sheet-header">
        <div class='container'>
            <div class="row container_dados">
                <div class="col-md-4">
                    <img class="tagmarLogo" src="systems/tagmar/templates/sheets/img/logo.png"/> 
                </div>
                <div class="col-md-8">
                    <h1 class="fairyDust" style="text-align: center; padding-top:20px;">Profissão</h1>
                </div>
            </div>
            <div class="row container_dados">
                <img src="{{item.img}}" data-edit="img" title="{{item.name}}" height="64" width="64"/>
                <h1 class="fairyDust"><input name="name" type="text" value="{{item.name}}" placeholder="Name"/></h1>
            </div>
            <div class="container container_dados">
                <div class="row dados">
                    <div class="col-md-2">
                        <label><h4 class="mediaeval">Descrição:</h4></label>
                    </div>
                    <div class="col-md-10">
                        <textarea class="mediaeval" name="data.descricao" value="{{data.descricao}}" style="font-size: 100%; height: 100px;">{{data.descricao}}</textarea>
                    </div>
                </div>
                <div class="row dados">
                    <div class="col-md-6">
                        <table>
                            <caption class="mediaeval">Tabela cálculo EH:</caption>
                            <tr style="text-align: left;">
                                <th class="mediaeval">1-2</th>
                                <th class="mediaeval">3-4-5</th>
                                <th class="mediaeval">6-7-8</th>
                                <th class="mediaeval">9-10</th>
                            </tr>
                            <tr>
                                <td>
                                    <input name="data.lista_eh.v1" type="number" value="{{data.lista_eh.v1}}" height="30"/>
                                </td>
                                <td>
                                    <input name="data.lista_eh.v2" type="number" value="{{data.lista_eh.v2}}" height="30"/>
                                </td>
                                <td>
                                    <input name="data.lista_eh.v3" type="number" value="{{data.lista_eh.v3}}" height="30"/>
                                </td>
                                <td>
                                    <input name="data.lista_eh.v4" type="number" value="{{data.lista_eh.v4}}" height="30"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table>
                            <caption class="mediaeval">Pontos para aquisição</caption>
                            <tr style="text-align: left;">
                                <th class="mediaeval">Habilidades</th>
                                <th class="mediaeval">Técnicas</th>
                                <th class="mediaeval">G.Armas</th>
                                <!--th class="mediaeval">Magías</th-->
                            </tr>
                            <tr>
                                <td>
                                    <input name="data.p_aquisicao.p_hab" type="number" value="{{data.p_aquisicao.p_hab}}"/>
                                </td>
                                <td>
                                    <input name="data.p_aquisicao.p_tec" type="number" value="{{data.p_aquisicao.p_tec}}"/>
                                </td>
                                <td>
                                    <input name="data.p_aquisicao.p_gra" type="number" value="{{data.p_aquisicao.p_gra}}"/>
                                </td>
                                <!--td>
                                    <input name="data.p_aquisicao.p_mag" type="number" value="{{data.p_aquisicao.p_mag}}"/>
                                </td-->
                            </tr>
                        </table>
                    </div>
                </div>
                <div class="row dados">
                    <div class="col-md-4">
                        <label><h4 class="mediaeval">Atrib.Pontos Magía:</h4></label>
                    </div>
                    <div class="col-md-2">
                        <select class="mediaeval" name="data.atrib_mag" type="text" value="{{data.atrib_mag}}" data-dtype="String" height="30">
                            {{#select data.atrib_mag}}
                            <option value=""></option>
                            <option value="INT">INT</option>
                            <option value="AUR">AUR</option>
                            <option value="CAR">CAR</option>
                            <option value="FOR">FOR</option>
                            <option value="FIS">FÍS</option>
                            <option value="AGI">AGI</option>
                            <option value="PER">PER</option>
                            {{/select}}
                        </select> 
                    </div>
                    <div class="col-md-2">
                        <label><h4 class="mediaeval">Grupo Penalizado:</h4></label>
                    </div>
                    <div class="col-md-4">
                        <select class="mediaeval" name="data.grupo_pen" type="text" value="{{data.grupo_pen}}" data-dtype="String" height="30">
                            {{#select data.grupo_pen}}
                            <option value=""></option>
                            <option value="profissional">Profissional</option>
                            <option value="manobra">Manobra</option>
                            <option value="conhecimento">Conhecimento</option>
                            <option value="subterfugio">Subterfúgio</option>
                            <option value="influencia">Influência</option>
                            <option value="geral">Geral</option>
                            {{/select}}
                        </select>      
                    </div>
                </div>
                <div class="row dados">
                    <div class="col-md-2">
                        <label><h4 class="mediaeval">Habilidade Nata:</h4></label>
                    </div>
                    <div class="col-md-4">
                        <input name="data.hab_nata" type="text" value="{{data.hab_nata}}" height="30"/>
                    </div>
                    <div class="col-md-4" style="text-align: right;">
                        <label><h4 class="mediaeval">Energia Heróica:</h4></label>
                    </div>
                    <div class="col-md-2">
                        <input name="data.eh_base" type="number" value="{{data.eh_base}}" height="30"/>
                    </div>
                </div>
                <div class="row dados">
                    <div class="col-md-3"><label><h4 class="mediaeval">Especialização:</h4></label></div>
                    <div class="col-md-7">
                        <input type="text" class="iEspecName" height="30"/>
                    </div>
                    <div class="col-md-2">
                        <h4 class="mediaeval"><a class="bAddEspec"><i class="fas fa-plus-circle"></i></a></h4>
                    </div>
                </div>
                <div class="row dados">
                    <div class="col-md-12">
                        <table>
                            <caption class="mediaeval">Especializações</caption>
                            <tr style="text-align: left;">
                                <th class="mediaeval">Especialização</th>
                                <th>Apagar</th>
                            </tr>
                            {{#each item.especializacoes as |espec_name key|}}
                                {{#ifdf espec_name ""}}
                                    <tr>
                                        <td class="mediaeval">{{espec_name}}</td>
                                        <td><a class="bApagaEspec" data-item-id="{{espec_name}}"><i class="fas fa-minus-circle"></i></a></td>
                                    </tr>
                                {{/ifdf}}
                            {{/each}}
                        </table>
                    </div>
                </div>
            </div>
        </div>   
    </header>
</form>
